# ── Server Config ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database Config ────────────────────────────────────────────────
# Use this for local MongoDB installed on your machine
MONGO_URI=mongodb://localhost:27017/smart-leads
# If using Docker Compose, the URI is typically:
# MONGO_URI=mongodb://mongodb:27017/smart-leads

# ── Security & Authentication ──────────────────────────────────────
# Generate a strong, random 64-character hex string for production.
# You can generate one via terminal: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET=replace_this_with_a_super_secret_jwt_key_in_production
JWT_EXPIRES_IN=7d

# ── CORS Settings ──────────────────────────────────────────────────
# Comma-separated list of allowed origins. 
# In production, set this to your exact frontend domain (e.g., https://dashboard.yourdomain.com)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
